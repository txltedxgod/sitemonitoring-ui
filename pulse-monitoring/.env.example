# Async SQLite database URL
DATABASE_URL=sqlite+aiosqlite:///./data/monitor.db

# How often the scheduler wakes up to look for due checks (seconds)
TICK_SECONDS=60

# Default check interval for new sites (minutes)
DEFAULT_INTERVAL_MINUTES=5

# Per-request HTTP timeout (seconds)
REQUEST_TIMEOUT=15

# Telegram notifications (leave empty to disable).
# Create a bot via @BotFather to get the token, and use @userinfobot to get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=INFO
